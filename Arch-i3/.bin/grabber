#!/bin/bash

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Function to display usage
usage() {
    echo "Usage: grabber <source_directory> <filename|*> <extension> [output_directory]"
    echo ""
    echo "Examples:"
    echo "  grabber ~/Downloads myfile txt              # Move specific file to current directory"
    echo "  grabber ~/Downloads * mp3 ~/Music           # Move all mp3 files to ~/Music"
    echo "  grabber /path/to/source document.pdf pdf    # Move specific PDF to current directory"
    echo ""
    echo "Arguments:"
    echo "  source_directory  - Directory to search for files"
    echo "  filename          - Specific filename (without extension) or * for all files"
    echo "  extension         - File extension (without dot)"
    echo "  output_directory  - Optional. Defaults to current directory"
    exit 1
}

# Check if at least 3 arguments are provided
if [ $# -lt 3 ]; then
    usage
fi

SOURCE_DIR="$1"
FILENAME="$2"
EXTENSION="$3"
OUTPUT_DIR="${4:-.}"  # Default to current directory if not specified

# Expand paths
SOURCE_DIR=$(realpath "$SOURCE_DIR" 2>/dev/null)
OUTPUT_DIR=$(realpath "$OUTPUT_DIR" 2>/dev/null)

# Validate source directory
if [ ! -d "$SOURCE_DIR" ]; then
    echo -e "${RED}Error: Source directory '$1' does not exist${NC}"
    exit 1
fi

# Validate output directory
if [ ! -d "$OUTPUT_DIR" ]; then
    echo -e "${RED}Error: Output directory '$OUTPUT_DIR' does not exist${NC}"
    exit 1
fi

# Remove leading dot from extension if present
EXTENSION="${EXTENSION#.}"

# Build search pattern
if [ "$FILENAME" = "*" ]; then
    PATTERN="*.$EXTENSION"
else
    PATTERN="${FILENAME}.$EXTENSION"
fi

# Find matching files
mapfile -t FILES < <(find "$SOURCE_DIR" -maxdepth 1 -type f -name "$PATTERN")

# Check if any files were found
if [ ${#FILES[@]} -eq 0 ]; then
    echo -e "${RED}No files matching '$PATTERN' found in $SOURCE_DIR${NC}"
    exit 1
fi

# Display files to be moved
echo -e "${YELLOW}Found ${#FILES[@]} file(s) to move:${NC}"
for file in "${FILES[@]}"; do
    echo "  - $(basename "$file")"
done

echo ""
echo -e "${YELLOW}Source:      ${NC}$SOURCE_DIR"
echo -e "${YELLOW}Destination: ${NC}$OUTPUT_DIR"
echo ""

# Ask for confirmation
read -p "Proceed with move? [y/N]: " -n 1 -r
echo

if [[ ! $REPLY =~ ^[Yy]$ ]]; then
    echo -e "${RED}Operation cancelled${NC}"
    exit 0
fi

# Move files
MOVED=0
FAILED=0

for file in "${FILES[@]}"; do
    filename=$(basename "$file")
    if mv "$file" "$OUTPUT_DIR/"; then
        echo -e "${GREEN}✓${NC} Moved: $filename"
        ((MOVED++))
    else
        echo -e "${RED}✗${NC} Failed: $filename"
        ((FAILED++))
    fi
done

echo ""
echo -e "${GREEN}Successfully moved: $MOVED${NC}"
if [ $FAILED -gt 0 ]; then
    echo -e "${RED}Failed: $FAILED${NC}"
fi
