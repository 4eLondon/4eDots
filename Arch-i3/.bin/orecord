#!/bin/bash
OUTPUT="$HOME/Videos/Recordings/recording-$(date +%Y%m%d-%H%M%S).mp4"
AUDIO_SOURCE="alsa_output.pci-0000_04_00.6.analog-stereo.monitor"

echo "Recording to: $OUTPUT"
echo "Press Ctrl+C to stop"

# RECOMMENDED: Hardware encoding (AMD GPU) - smoothest performance
ffmpeg -thread_queue_size 1024 -f x11grab -framerate 30 -video_size 1920x1080 \
  -draw_mouse 1 -i :0.0 \
  -thread_queue_size 1024 -f pulse -i "$AUDIO_SOURCE" \
  -vaapi_device /dev/dri/renderD128 \
  -vf 'format=nv12,hwupload' \
  -c:v h264_vaapi -qp 23 -bf 0 \
  -c:a aac -b:a 128k -ar 48000 \
  -max_muxing_queue_size 4096 \
  "$OUTPUT"

