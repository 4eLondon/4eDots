
# i3 config file (v4)
# Warm Earth Tones Color Scheme

# Color definitions
set $bg           #111111
set $fg           #d3d3d3
set $black        #382c2f
set $gray         #ac9377
set $red          #48393a
set $red_bright   #baa17e
set $green        #65534d
set $green_bright #bca282
set $yellow       #79665a
set $yellow_bright #c1a67e
set $blue         #836e5e
set $blue_bright  #cfb48e
set $magenta      #8e7766
set $magenta_bright #d1baa3
set $cyan         #917781
set $cyan_bright  #dfc39b
set $white        #9a846d
set $white_bright #eed8c4

# Window colors
#                       border          background      text            indicator       child_border
client.focused          $green_bright   $green_bright   $bg             $cyan_bright    $green_bright
client.focused_inactive $black          $black          $white          $black          $black
client.unfocused        $bg             $bg             $gray           $bg             $red
client.urgent           $red_bright     $red_bright     $bg             $red_bright     $red_bright
client.placeholder      $bg             $bg             $white          $bg             $bg
client.background       $bg

# Bar configuration
bar {
    status_command i3status
    position top
    
    colors {
        background $bg
        statusline $fg
        separator  $gray
        
        #                  border          background      text
        focused_workspace  $green_bright   $green_bright   $bg
        active_workspace   $yellow         $yellow         $bg
        inactive_workspace $black          $black          $white
        urgent_workspace   $red_bright     $red_bright     $bg
        binding_mode       $cyan_bright    $cyan_bright    $bg
    }
    
    font pango:JetBrainsMono Nerd Font 10
}

for_window [class="^Steam$"] floating enable
for_window [class="^Steam$" title="^Steam$"] floating disable, border pixel 2
for_window [class="^Steam$" title="^Friends"] floating enable
for_window [class="^Steam$" title="Steam - News"] floating enable
for_window [class="^Steam$" title=".* - Chat"] floating enable
for_window [class="^Steam$" title="^Settings"] floating enable
for_window [class="^Steam$" title=".* - event started"] floating enable
for_window [class="^Steam$" title=".* CD key"] floating enable
for_window [class="^Steam$" title="^Steam - Self Updater"] floating enable
for_window [class="^Steam$" title="^Screenshot Uploader"] floating enable
for_window [class="^Steam$" title="Steam Guard"] floating enable
for_window [class="^Steam$" title="Steam - Browser"] floating enable
for_window [class="^steam_app_"] border pixel 0, fullscreen enable

# Font for window titles
font pango:JetBrainsMono Nerd Font 10

gaps inner 6
gaps outer 2

# Window borders
default_border pixel 2
default_floating_border pixel 2
hide_edge_borders smart

###################################
#        Startup and core
###################################

set $mod Mod4
set $term kitty

exec --no-startup-id dunst
exec --no-startup-id clipmenud
bindsym $mod+v exec --no-startup-id clipmenu
exec --no-startup-id /usr/lib/opentabletdriver/OpenTabletDriver.Daemon
exec --no-startup-id feh --bg-scale ~/Pictures/Wallpapers/4.jpg
exec --no-startup-id picom --config ~/.config/picom/picom.conf -b
exec --no-startup-id udiskie --tray --notify
exec --no-startup-id ~/bin/battery-watch.sh

###################################
#           Keybinds
###################################

# Launchers
bindsym $mod+q exec $term
bindsym $mod+d exec dmenu_run
bindsym $mod+c kill

# windows
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right
bindsym $mod+f fullscreen toggle
for_window [class="Pavucontrol"] floating enable
for_window [class="Blueman-manager"] floating enable
for_window [window_role="pop-up"] floating enable
for_window [window_role="task_dialog"] floating enable

mode "resize" {
    bindsym h resize shrink width 10 px or 10 ppt
    bindsym j resize grow height 10 px or 10 ppt
    bindsym k resize shrink height 10 px or 10 ppt
    bindsym l resize grow width 10 px or 10 ppt
    
    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"

bindsym $mod+Tab workspace next
bindsym $mod+Shift+Tab workspace prev
bindsym $mod+z workspace back_and_forth

## Layout modes
bindsym $mod+n split v
bindsym $mod+b split h

bindsym $mod+e layout toggle split
bindsym $mod+w layout tabbed
bindsym $mod+s layout stacking

bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle


# Utinlity keys

# Screenshot
bindsym Print exec --no-startup-id sh -c 'maim -u "/tmp/screenshot.png" && xclip -selection clipboard -t image/png -i "/tmp/screenshot.png" && mv "/tmp/screenshot.png" "$HOME/Pictures/Screenshots/screenshot-$(date +%F-%T).png"'

bindsym Shift+Print exec --no-startup-id sh -c 'maim -s -u "/tmp/screenshot.png" && xclip -selection clipboard -t image/png -i "/tmp/screenshot.png" && mv "/tmp/screenshot.png" "$HOME/Pictures/Screenshots/screenshot-$(date +%F-%T).png"'
# Brightness keys
bindsym XF86MonBrightnessUp exec --no-startup-id brightnessctl set +10%
bindsym XF86MonBrightnessDown exec --no-startup-id brightnessctl set 10%-

# Volume keys
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +5%
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -5%
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle

# Use $mod+mouse to drag floating windows
floating_modifier $mod
bindsym $mod+a focus parent
bindsym $mod+Shift+a focus child


# Workspaces
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"

bindsym $mod+1 workspace $ws1
bindsym $mod+2 workspace $ws2
bindsym $mod+3 workspace $ws3
bindsym $mod+4 workspace $ws4
bindsym $mod+5 workspace $ws5
bindsym $mod+6 workspace $ws6

bindsym $mod+Shift+1 move container to workspace $ws1
bindsym $mod+Shift+2 move container to workspace $ws2
bindsym $mod+Shift+3 move container to workspace $ws3
bindsym $mod+Shift+4 move container to workspace $ws4
bindsym $mod+Shift+5 move container to workspace $ws5
bindsym $mod+Shift+6 move container to workspace $ws6

# Exit and reload
bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart
bindsym $mod+Shift+e exec i3-nagbar -t warning -m "Exit i3?" -b "Yes" "i3-msg exit"

set $mode_system System: (l) lock, (e) logout, (s) suspend, (r) reboot, (p) poweroff
mode "$mode_system" {
    bindsym l exec --no-startup-id i3lock -c 000000, mode "default"
    bindsym e exec --no-startup-id i3-msg exit, mode "default"
    bindsym s exec --no-startup-id systemctl suspend, mode "default"
    bindsym r exec --no-startup-id systemctl reboot, mode "default"
    bindsym p exec --no-startup-id systemctl poweroff, mode "default"
    
    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+Shift+q mode "$mode_system"


