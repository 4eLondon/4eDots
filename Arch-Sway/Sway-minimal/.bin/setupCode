#!/usr/bin/env bash
set -euo pipefail

RED=$'\033[0;31m'; GREEN=$'\033[0;32m'; YELLOW=$'\033[1;33m'
CYAN=$'\033[0;36m'; BOLD=$'\033[1m'; DIM=$'\033[2m'; RESET=$'\033[0m'

info()    { echo -e "${CYAN}[info]${RESET}  $*"; }
success() { echo -e "${GREEN}[ ok ]${RESET}  $*"; }
warn()    { echo -e "${YELLOW}[warn]${RESET}  $*"; }
error()   { echo -e "${RED}[err ]${RESET}  $*" >&2; }
verbose() { [[ "$OPT_VERBOSE" == 1 ]] && echo -e "${DIM}[dbg ]  $*${RESET}" || true; }
header()  { echo -e "\n${BOLD}── $* ──${RESET}"; }

OPT_INSTALL=0; OPT_REMOVE=0; OPT_STATUS=0; OPT_ALL=0; OPT_YES=0; OPT_VERBOSE=0

# ── package lists ─────────────────────────────────────────────────────────────
PKGS_assembly=( nasm yasm binutils )
AUR_assembly=()

PKGS_bash=( bash bash-completion shellcheck shfmt bats )
AUR_bash=()

PKGS_c=( gcc make cmake valgrind strace ltrace )
AUR_c=()

PKGS_cpp=( gcc make cmake ninja valgrind boost catch2 )
AUR_cpp=( ccache )

PKGS_csharp=( dotnet-sdk-9.0 dotnet-runtime-9.0 aspnet-runtime-9.0 mono )
AUR_csharp=( omnisharp-roslyn )

PKGS_elixir=( elixir erlang erlang-nox )
AUR_elixir=( elixir-ls )

PKGS_go=( go gopls delve )
AUR_go=( go-staticcheck )

PKGS_haskell=( ghc stack cabal-install haskell-hls-bin hlint )
AUR_haskell=( stylish-haskell )

PKGS_java=( jdk-openjdk jre-openjdk maven gradle )
AUR_java=( jdtls )

PKGS_lua=( lua luajit luarocks )
AUR_lua=( lua-language-server )

PKGS_python=( python python-pip python-virtualenv python-pipx pyright ruff python-black python-pytest ipython )
AUR_python=()

PKGS_ruby=( ruby rubygems )
AUR_ruby=( ruby-solargraph rbenv )

PKGS_rust=( rust rust-analyzer cargo rustfmt clippy )
AUR_rust=( cargo-edit cargo-watch )

PKGS_webdev=( nodejs npm typescript prettier eslint )
AUR_webdev=( vscode-html-languageserver vscode-css-languageserver typescript-language-server )

ALL_LANGS=( assembly bash c cpp csharp elixir go haskell java lua python ruby rust webdev )

# ── helpers ───────────────────────────────────────────────────────────────────
pkg_installed() { pacman -Qi "$1" &>/dev/null; }

aur_helper() {
    for h in yay paru trizen; do
        command -v "$h" &>/dev/null && { echo "$h"; return; }
    done
    error "No AUR helper found (yay / paru / trizen)."; exit 1
}

aur_installed() { local h; h=$(aur_helper); "$h" -Qi "$1" &>/dev/null; }

install_pkgs() {
    local t=()
    for p in "$@"; do pkg_installed "$p" || t+=("$p"); done
    [[ ${#t[@]} -eq 0 ]] && return
    sudo pacman -S --needed --noconfirm "${t[@]}"
}

install_aur_pkgs() {
    local h; h=$(aur_helper); local t=()
    for p in "$@"; do { pkg_installed "$p" || aur_installed "$p"; } || t+=("$p"); done
    [[ ${#t[@]} -eq 0 ]] && return
    "$h" -S --needed --noconfirm "${t[@]}"
}

purge_pkgs() {
    local t=()
    for p in "$@"; do pkg_installed "$p" && t+=("$p") || true; done
    [[ ${#t[@]} -eq 0 ]] && return
    sudo pacman -Rns --noconfirm "${t[@]}"
}

purge_aur_pkgs() {
    local h; h=$(aur_helper); local t=()
    for p in "$@"; do { pkg_installed "$p" || aur_installed "$p"; } && t+=("$p") || true; done
    [[ ${#t[@]} -eq 0 ]] && return
    "$h" -Rns --noconfirm "${t[@]}"
}

resolve_langs() {
    local -n _o=$1; shift
    if [[ $# -eq 0 || "$OPT_ALL" == 1 ]]; then _o=("${ALL_LANGS[@]}"); return; fi
    for lang in "$@"; do
        local ok=0
        for l in "${ALL_LANGS[@]}"; do [[ "$l" == "$lang" ]] && ok=1 && break; done
        [[ $ok -eq 0 ]] && { error "Unknown language: $lang"; exit 1; }
        _o+=("$lang")
    done
}

# ── actions ───────────────────────────────────────────────────────────────────
do_install() {
    local langs=(); resolve_langs langs "$@"
    for lang in "${langs[@]}"; do
        header "Installing $lang"
        local pkgs=() aur=()
        eval "pkgs=(\"\${PKGS_${lang}[@]}\")"
        eval "aur=(\"\${AUR_${lang}[@]}\")"
        [[ ${#pkgs[@]} -gt 0 ]] && install_pkgs     "${pkgs[@]}"
        [[ ${#aur[@]}  -gt 0 ]] && install_aur_pkgs "${aur[@]}"
        success "$lang done."
    done
}

do_remove() {
    local langs=(); resolve_langs langs "$@"
    if [[ "$OPT_YES" != 1 ]]; then
        echo -e "\n${RED}${BOLD}⚠  Remove:${RESET} ${langs[*]}"
        read -rp "  Type 'yes' to confirm: " _c
        [[ "$_c" != "yes" ]] && { warn "Aborted."; exit 0; }
    fi
    for lang in "${langs[@]}"; do
        header "Removing $lang"
        local pkgs=() aur=()
        eval "pkgs=(\"\${PKGS_${lang}[@]}\")"
        eval "aur=(\"\${AUR_${lang}[@]}\")"
        [[ ${#aur[@]}  -gt 0 ]] && purge_aur_pkgs "${aur[@]}"
        [[ ${#pkgs[@]} -gt 0 ]] && purge_pkgs     "${pkgs[@]}"
        success "$lang removed."
    done
}

do_status() {
    local langs=(); resolve_langs langs "$@"
    header "Status"
    printf "  ${BOLD}%-12s  %-15s  %s${RESET}\n" "Language" "Status" "Missing"
    printf "  %-12s  %-15s  %s\n"                "────────" "──────" "───────"
    for lang in "${langs[@]}"; do
        local pkgs=() aur=() missing=()
        eval "pkgs=(\"\${PKGS_${lang}[@]}\")"
        eval "aur=(\"\${AUR_${lang}[@]}\")"
        local all=("${pkgs[@]}" "${aur[@]}")
        for p in "${all[@]}"; do
            { pkg_installed "$p" || aur_installed "$p"; } || missing+=("$p")
        done
        if   [[ ${#missing[@]} -eq 0 ]];             then printf "  %-12s  ${GREEN}%-15s${RESET}  —\n"   "$lang" "✔ installed"
        elif [[ ${#missing[@]} -eq ${#all[@]} ]];    then printf "  %-12s  ${RED}%-15s${RESET}  %s\n"    "$lang" "✘ not installed" "${missing[*]}"
        else                                              printf "  %-12s  ${YELLOW}%-15s${RESET}  %s\n"  "$lang" "~ partial"       "${missing[*]}"
        fi
    done
    echo
}

do_list() {
    header "Languages"
    for lang in "${ALL_LANGS[@]}"; do
        local pkgs=() aur=()
        eval "pkgs=(\"\${PKGS_${lang}[@]}\")"
        eval "aur=(\"\${AUR_${lang}[@]}\")"
        printf "  ${BOLD}%-12s${RESET}  %s\n" "$lang" "${pkgs[*]}"
        [[ ${#aur[@]} -gt 0 ]] && printf "  %-12s  ${DIM}aur: %s${RESET}\n" "" "${aur[*]}"
    done
    echo
}

usage() {
cat <<EOF
  [ Flags ]
  -i   install
  -r   remove
  -s   status
  -a   all 
  -l   list
  -y   no prompt
  -v   verbose
  -h   help

  [ Examples ]
  setupCode -ia 
  setupCode -i rust go
  setupCode -rya
  setupCode -r python
  setupCode -s
  setupCode -s c cpp rust

EOF
}

# ── entry ─────────────────────────────────────────────────────────────────────
[[ $# -eq 0 ]] && { usage; exit 0; }

while getopts ":irsalyvh" opt; do
    case "$opt" in
        i) OPT_INSTALL=1 ;; r) OPT_REMOVE=1  ;; s) OPT_STATUS=1 ;;
        a) OPT_ALL=1     ;; l) do_list; exit 0 ;; y) OPT_YES=1   ;;
        v) OPT_VERBOSE=1 ;; h) usage; exit 0   ;;
        \?) error "Unknown flag: -${OPTARG}"; exit 1 ;;
    esac
done
shift $(( OPTIND - 1 ))

n=$(( OPT_INSTALL + OPT_REMOVE + OPT_STATUS ))
[[ $n -eq 0 ]] && { error "Need an action: -i  -r  -s"; exit 1; }
[[ $n -gt 1 ]] && { error "One action at a time."; exit 1; }
[[ "$OPT_ALL" == 1 && $# -gt 0 ]] && warn "-a set; ignoring: $*"

[[ "$OPT_INSTALL" == 1 ]] && do_install "$@"
[[ "$OPT_REMOVE"  == 1 ]] && do_remove  "$@"
[[ "$OPT_STATUS"  == 1 ]] && do_status  "$@"
