#!/usr/bin/env bash
set -euo pipefail

RED=$'\033[0;31m'; GREEN=$'\033[0;32m'; YELLOW=$'\033[1;33m'
CYAN=$'\033[0;36m'; BOLD=$'\033[1m'; DIM=$'\033[2m'; RESET=$'\033[0m'

info()    { echo -e "${CYAN}[info]${RESET}  $*"; }
success() { echo -e "${GREEN}[ ok ]${RESET}  $*"; }
warn()    { echo -e "${YELLOW}[warn]${RESET}  $*"; }
error()   { echo -e "${RED}[err ]${RESET}  $*" >&2; }
verbose() { [[ "$OPT_VERBOSE" == 1 ]] && echo -e "${DIM}[dbg ]  $*${RESET}" || true; }
header()  { echo -e "\n${BOLD}── $* ──${RESET}"; }

OPT_INSTALL=0; OPT_REMOVE=0; OPT_STATUS=0; OPT_YES=0; OPT_VERBOSE=0

NVIM_CONFIG="$HOME/.config/nvim"
NVIM_LUA="$NVIM_CONFIG/lua"
LSP_DEST="$NVIM_LUA/lsp.lua"
INIT="$NVIM_CONFIG/init.lua"
LSP_MARKER="-- [setupLSP]"
LSP_REQUIRE='require("lsp")'

# ── language → LSP server mapping ─────────────────────────────────────────────
# LSP_PROBE[lang]  = a setupCode-installed package that signals lang is present
# LSP_PACMAN[lang] = space-separated pacman LSP packages
# LSP_AUR[lang]    = space-separated AUR LSP packages

declare -A LSP_PROBE LSP_PACMAN LSP_AUR

LSP_PROBE[assembly]="nasm";        LSP_PACMAN[assembly]="asm-lsp";           LSP_AUR[assembly]=""
LSP_PROBE[bash]="shellcheck";      LSP_PACMAN[bash]="bash-language-server";  LSP_AUR[bash]=""
LSP_PROBE[c]="gcc";                LSP_PACMAN[c]="clang";                    LSP_AUR[c]=""
LSP_PROBE[cpp]="gcc";              LSP_PACMAN[cpp]="clang";                  LSP_AUR[cpp]=""
LSP_PROBE[csharp]="dotnet-sdk-9.0"; LSP_PACMAN[csharp]="";                  LSP_AUR[csharp]="omnisharp-roslyn"
LSP_PROBE[elixir]="elixir";        LSP_PACMAN[elixir]="";                    LSP_AUR[elixir]="elixir-ls"
LSP_PROBE[go]="go";                LSP_PACMAN[go]="gopls";                   LSP_AUR[go]=""
LSP_PROBE[haskell]="ghc";          LSP_PACMAN[haskell]="haskell-hls-bin";    LSP_AUR[haskell]=""
LSP_PROBE[java]="jdk-openjdk";     LSP_PACMAN[java]="";                      LSP_AUR[java]="jdtls"
LSP_PROBE[lua]="lua";              LSP_PACMAN[lua]="";                       LSP_AUR[lua]="lua-language-server"
LSP_PROBE[python]="python";        LSP_PACMAN[python]="pyright";             LSP_AUR[python]=""
LSP_PROBE[ruby]="ruby";            LSP_PACMAN[ruby]="";                      LSP_AUR[ruby]="ruby-solargraph"
LSP_PROBE[rust]="rust";            LSP_PACMAN[rust]="rust-analyzer";         LSP_AUR[rust]=""
LSP_PROBE[webdev]="nodejs";        LSP_PACMAN[webdev]="";                    LSP_AUR[webdev]="vscode-html-languageserver vscode-css-languageserver typescript-language-server"

ALL_LANGS=( assembly bash c cpp csharp elixir go haskell java lua python ruby rust webdev )

# ── helpers ───────────────────────────────────────────────────────────────────
pkg_installed() { pacman -Qi "$1" &>/dev/null; }

aur_helper() {
    for h in yay paru trizen; do
        command -v "$h" &>/dev/null && { echo "$h"; return; }
    done
    error "No AUR helper found (yay / paru / trizen)."; exit 1
}

pkg_or_aur_installed() {
    if pkg_installed "$1"; then return 0; fi
    local h; h=$(aur_helper 2>/dev/null) || return 1
    "$h" -Qi "$1" &>/dev/null
}

# ── language detection ────────────────────────────────────────────────────────
detect_installed_langs() {
    local -n _out=$1
    for lang in "${ALL_LANGS[@]}"; do
        local probe="${LSP_PROBE[$lang]:-}"
        [[ -z "$probe" ]] && continue
        if pkg_installed "$probe"; then
            verbose "Detected $lang (probe: $probe)"
            _out+=("$lang")
        else
            verbose "Not detected: $lang (probe $probe missing)"
        fi
    done
}

# ── guards ────────────────────────────────────────────────────────────────────
check_nvim_config() {
    [[ -d "$NVIM_CONFIG" ]] || { error "~/.config/nvim not found. Aborting."; exit 1; }
    [[ -f "$INIT"        ]] || { error "~/.config/nvim/init.lua not found. Aborting."; exit 1; }
}



# ── per-language install / remove ─────────────────────────────────────────────
lsp_pkgs_for() {
    local lang="$1"
    local -n _pac=$2 _aur=$3
    read -ra _pac <<< "${LSP_PACMAN[$lang]:-}"
    read -ra _aur <<< "${LSP_AUR[$lang]:-}"
    # drop empty strings
    _pac=( "${_pac[@]:-}" ); _pac=( "${_pac[@]}" )
    _aur=( "${_aur[@]:-}" ); _aur=( "${_aur[@]}" )
}

install_lang_lsp() {
    local lang="$1"
    local pac=() aur=()
    lsp_pkgs_for "$lang" pac aur

    if [[ ${#pac[@]} -gt 0 && -n "${pac[0]}" ]]; then
        local need=()
        for p in "${pac[@]}"; do pkg_installed "$p" || need+=("$p"); done
        [[ ${#need[@]} -gt 0 ]] && sudo pacman -S --needed --noconfirm "${need[@]}"
    fi

    if [[ ${#aur[@]} -gt 0 && -n "${aur[0]}" ]]; then
        local h; h=$(aur_helper)
        local need=()
        for p in "${aur[@]}"; do pkg_or_aur_installed "$p" 2>/dev/null || need+=("$p"); done
        [[ ${#need[@]} -gt 0 ]] && "$h" -S --needed --noconfirm "${need[@]}"
    fi
}

remove_lang_lsp() {
    local lang="$1"
    local pac=() aur=()
    lsp_pkgs_for "$lang" pac aur

    if [[ ${#aur[@]} -gt 0 && -n "${aur[0]}" ]]; then
        local h; h=$(aur_helper)
        local have=()
        for p in "${aur[@]}"; do
            pkg_or_aur_installed "$p" 2>/dev/null && have+=("$p") || true
        done
        [[ ${#have[@]} -gt 0 ]] && "$h" -Rns --noconfirm "${have[@]}"
    fi

    if [[ ${#pac[@]} -gt 0 && -n "${pac[0]}" ]]; then
        local have=()
        for p in "${pac[@]}"; do
            pkg_installed "$p" && have+=("$p") || true
        done
        [[ ${#have[@]} -gt 0 ]] && sudo pacman -Rns --noconfirm "${have[@]}"
    fi
}

# ── nvim wiring ───────────────────────────────────────────────────────────────
deploy_lsp_lua() {
    mkdir -p "$NVIM_LUA"
    cat > "$LSP_DEST" << 'EOFLUA'
-- [setupLSP] managed file — do not edit by hand
local lspconfig = require("lspconfig")

local on_attach = function(_, bufnr)
    local map = function(keys, func, desc)
        vim.keymap.set("n", keys, func, { buffer = bufnr, desc = "LSP: " .. desc })
    end
    map("gd",        vim.lsp.buf.definition,       "Go to Definition")
    map("gD",        vim.lsp.buf.declaration,      "Go to Declaration")
    map("gr",        vim.lsp.buf.references,       "References")
    map("gi",        vim.lsp.buf.implementation,   "Go to Implementation")
    map("K",         vim.lsp.buf.hover,            "Hover Docs")
    map("<leader>rn",vim.lsp.buf.rename,           "Rename")
    map("<leader>ca",vim.lsp.buf.code_action,      "Code Action")
    map("<leader>f", function() vim.lsp.buf.format({ async = true }) end, "Format")
end

local caps = vim.lsp.protocol.make_client_capabilities()
pcall(function()
    caps = require("cmp_nvim_lsp").default_capabilities(caps)
end)

-- ── C / C++ ──────────────────────────────────────────────────────────────────
pcall(function() lspconfig.clangd.setup({ on_attach = on_attach, capabilities = caps }) end)

-- ── C# ───────────────────────────────────────────────────────────────────────
pcall(function()
    lspconfig.omnisharp.setup({
        on_attach   = on_attach,
        capabilities = caps,
        cmd         = { "omnisharp", "--languageserver", "--hostPID", tostring(vim.fn.getpid()) },
    })
end)

-- ── Go ───────────────────────────────────────────────────────────────────────
pcall(function() lspconfig.gopls.setup({ on_attach = on_attach, capabilities = caps }) end)

-- ── Lua ──────────────────────────────────────────────────────────────────────
pcall(function()
    lspconfig.lua_ls.setup({
        on_attach    = on_attach,
        capabilities = caps,
        settings     = {
            Lua = {
                runtime  = { version = "LuaJIT" },
                workspace = { library = vim.api.nvim_get_runtime_file("", true), checkThirdParty = false },
                telemetry = { enable = false },
                diagnostics = { globals = { "vim" } },
            },
        },
    })
end)

-- ── Python ───────────────────────────────────────────────────────────────────
pcall(function() lspconfig.pyright.setup({ on_attach = on_attach, capabilities = caps }) end)

-- ── Web dev (HTML / CSS / TypeScript) ────────────────────────────────────────
pcall(function() lspconfig.html.setup({ on_attach = on_attach, capabilities = caps }) end)
pcall(function() lspconfig.cssls.setup({ on_attach = on_attach, capabilities = caps }) end)
pcall(function() lspconfig.ts_ls.setup({ on_attach = on_attach, capabilities = caps }) end)

-- ── Assembly ─────────────────────────────────────────────────────────────────
pcall(function() lspconfig.asm_lsp.setup({ on_attach = on_attach, capabilities = caps }) end)

-- ── Bash ─────────────────────────────────────────────────────────────────────
pcall(function() lspconfig.bashls.setup({ on_attach = on_attach, capabilities = caps }) end)

-- ── Elixir ───────────────────────────────────────────────────────────────────
pcall(function() lspconfig.elixirls.setup({ on_attach = on_attach, capabilities = caps,
    cmd = { "elixir-ls" } }) end)

-- ── Haskell ──────────────────────────────────────────────────────────────────
pcall(function() lspconfig.hls.setup({ on_attach = on_attach, capabilities = caps }) end)

-- ── Java ─────────────────────────────────────────────────────────────────────
pcall(function() lspconfig.jdtls.setup({ on_attach = on_attach, capabilities = caps }) end)

-- ── Ruby ─────────────────────────────────────────────────────────────────────
pcall(function() lspconfig.solargraph.setup({ on_attach = on_attach, capabilities = caps }) end)

-- ── Rust ─────────────────────────────────────────────────────────────────────
pcall(function() lspconfig.rust_analyzer.setup({ on_attach = on_attach, capabilities = caps }) end)
EOFLUA
    verbose "Wrote $LSP_DEST"
    if ! grep -qF -- "$LSP_MARKER" "$INIT"; then
        printf '\n%s\n%s\n' "$LSP_MARKER" "$LSP_REQUIRE" >> "$INIT"
    fi
    success "lsp.lua deployed."
}

undeploy_lsp_lua() {
    if [[ -f "$LSP_DEST" ]]; then
        rm "$LSP_DEST"
        success "lsp.lua removed."
    else
        info "lsp.lua not deployed."
    fi
    if grep -qF -- "$LSP_MARKER" "$INIT" 2>/dev/null; then
        grep -vF -- "$LSP_MARKER" "$INIT" | grep -vF -- "$LSP_REQUIRE" > "${INIT}.tmp"
        mv "${INIT}.tmp" "$INIT"
        success "init.lua cleaned."
    fi
}

# ── actions ───────────────────────────────────────────────────────────────────
do_install() {
    check_nvim_config
    header "Detecting installed languages"
    local detected=()
    detect_installed_langs detected

    if [[ ${#detected[@]} -eq 0 ]]; then
        warn "No setupCode-managed languages detected."
        warn "Install languages first with: setupCode -i <lang>"
        warn "Deploying lsp.lua only — no LSP servers installed."
        deploy_lsp_lua
        exit 0
    fi

    info "Detected: ${detected[*]}"

    header "Installing LSP servers"
    local skipped=()
    for lang in "${detected[@]}"; do
        local pac=() aur=()
        lsp_pkgs_for "$lang" pac aur
        local has=0
        [[ ${#pac[@]} -gt 0 && -n "${pac[0]:-}" ]] && has=1
        [[ ${#aur[@]} -gt 0 && -n "${aur[0]:-}" ]] && has=1
        if [[ $has -eq 0 ]]; then skipped+=("$lang"); continue; fi
        info "  $lang…"
        install_lang_lsp "$lang"
        success "  $lang LSP done."
    done

    [[ ${#skipped[@]} -gt 0 ]] && warn "No LSP server defined for: ${skipped[*]}"

    deploy_lsp_lua
    success "All done. Restart Neovim."
}

do_remove() {
    check_nvim_config
    if [[ "$OPT_YES" != 1 ]]; then
        echo -e "\n${RED}${BOLD}⚠  Remove all managed LSP servers and nvim wiring?${RESET}"
        read -rp "  Type 'yes' to confirm: " _c
        [[ "$_c" != "yes" ]] && { warn "Aborted."; exit 0; }
    fi

    header "Removing LSP servers"
    for lang in "${ALL_LANGS[@]}"; do
        local pac=() aur=()
        lsp_pkgs_for "$lang" pac aur
        local has=0
        [[ ${#pac[@]} -gt 0 && -n "${pac[0]:-}" ]] && has=1
        [[ ${#aur[@]} -gt 0 && -n "${aur[0]:-}" ]] && has=1
        [[ $has -eq 0 ]] && continue
        verbose "Removing LSP for $lang"
        remove_lang_lsp "$lang"
    done

    undeploy_lsp_lua
    success "Done. Restart Neovim."
}

do_status() {
    check_nvim_config
    header "Neovim wiring"
    [[ -f "$LSP_DEST" ]]                          \
        && echo -e "  lsp.lua       ${GREEN}✔ deployed${RESET}" \
        || echo -e "  lsp.lua       ${RED}✘ missing${RESET}"
    grep -qF "$LSP_MARKER" "$INIT" 2>/dev/null    \
        && echo -e "  init.lua      ${GREEN}✔ hooked${RESET}"   \
        || echo -e "  init.lua      ${RED}✘ not hooked${RESET}"

    header "LSP servers (keyed to installed languages)"
    printf "  ${BOLD}%-12s  %-18s  %s${RESET}\n" "Language" "Lang present" "LSP status"
    printf "  %-12s  %-18s  %s\n"                "────────" "────────────" "──────────"

    for lang in "${ALL_LANGS[@]}"; do
        local probe="${LSP_PROBE[$lang]:-}"
        local lang_label lang_clr
        if [[ -n "$probe" ]] && pkg_installed "$probe"; then
            lang_label="✔ installed"; lang_clr="$GREEN"
        else
            lang_label="✘ not installed"; lang_clr="$RED"
        fi

        local pac=() aur=()
        lsp_pkgs_for "$lang" pac aur
        local all_lsp=()
        [[ ${#pac[@]} -gt 0 && -n "${pac[0]:-}" ]] && all_lsp+=( "${pac[@]}" )
        [[ ${#aur[@]} -gt 0 && -n "${aur[0]:-}" ]] && all_lsp+=( "${aur[@]}" )

        local lsp_label lsp_clr
        if [[ ${#all_lsp[@]} -eq 0 ]]; then
            lsp_label="— no server defined"; lsp_clr="$DIM"
        else
            local count=0
            for p in "${all_lsp[@]}"; do pkg_or_aur_installed "$p" 2>/dev/null && (( count++ )) || true; done
            if   [[ $count -eq ${#all_lsp[@]} ]]; then lsp_label="✔ installed";    lsp_clr="$GREEN"
            elif [[ $count -eq 0 ]];              then lsp_label="✘ not installed"; lsp_clr="$RED"
            else                                       lsp_label="~ partial";       lsp_clr="$YELLOW"
            fi
        fi

        printf "  %-12s  ${lang_clr}%-18s${RESET}  ${lsp_clr}%s${RESET}\n" \
            "$lang" "$lang_label" "$lsp_label"
    done
    echo
}

usage() {
cat <<EOF

  [ Flags ]
  -i   install   detect installed langs, install matching LSP servers
  -r   remove    remove all managed LSP servers + nvim wiring
  -s   status    show lang presence and LSP state for every language
  -y   no prompt
  -v   verbose
  -h   help

  [ Examples ]
  setupLSP -i
  setupLSP -ry
  setupLSP -s

EOF
}

# ── entry ─────────────────────────────────────────────────────────────────────
[[ $# -eq 0 ]] && { usage; exit 0; }

while getopts ":isryvh" opt; do
    case "$opt" in
        i) OPT_INSTALL=1 ;; r) OPT_REMOVE=1  ;; s) OPT_STATUS=1 ;;
        y) OPT_YES=1     ;; v) OPT_VERBOSE=1  ;; h) usage; exit 0 ;;
        \?) error "Unknown flag: -${OPTARG}"; exit 1 ;;
    esac
done

n=$(( OPT_INSTALL + OPT_REMOVE + OPT_STATUS ))
[[ $n -eq 0 ]] && { error "Need an action: -i  -r  -s"; exit 1; }
[[ $n -gt 1 ]] && { error "One action at a time."; exit 1; }

[[ "$OPT_INSTALL" == 1 ]] && do_install
[[ "$OPT_REMOVE"  == 1 ]] && do_remove
[[ "$OPT_STATUS"  == 1 ]] && do_status

